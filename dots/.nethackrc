# USED ON Nethack 3.7.0 when 3.6.9 was latest stable
# brew install nethack --HEAD
# brew upgrade nethack --fetch-HEAD


# Needed om macOS
OPTIONS=altmeta

OPTIONS=!tutorial

# CHOOSE=elf,human
# [human]
# OPTIONS=role:wiz,race:hum,align:neu,gender:fem
# [elf]
# OPTIONS=role:wiz,race:elf,align:cha,gender:mal

# Names
OPTIONS=name:Lenn, dogname:Lea, catname:Lea
# female to include valkyrie
OPTIONS=gender:female
# OPTIONS=role:rogue, race:human

OPTIONS=fruit:pizza
OPTIONS=autodig:1

# Show experience points and time/ticks
OPTIONS=showexp, time
OPTIONS=showscore
# HP bar behind name
OPTIONS=hitpointbar
# Highlight piles of stuff
OPTIONS=hilite_pile
# Highlight pet
OPTIONS=hilite_pet

# Wield again pushes the old weapon into alternate slot
# OPTIONS=pushweapon

# Auto save each level
OPTIONS=checkpoint

# Auto pickup only items considered "generally safe":
# gold, scrolls, potions, wands, rings, amulets, and spellbooks.
OPTIONS=autopickup, pickup_types:$?!/="+

# Always pick these:
AUTOPICKUP_EXCEPTION="<magic lamp"

# But don't pickup a scroll of scare monster
AUTOPICKUP_EXCEPTION=">scroll of scare monster"
AUTOPICKUP_EXCEPTION=">worthless piece of"


OPTIONS=statuslines:3

OPTIONS=statushilites:3
# OPTIONS=hilite_status

OPTIONS=hilite_status:hunger/satiated/yellow&dim/hungry/yellow&inverse/weak/red&inverse
OPTIONS=hilite_status:hunger/fainting/blue&inverse/fainted/black&inverse
OPTIONS=hilite_status:hunger/starved/black&inverse&bold
OPTIONS=hilite_status:hunger/changed/cyan&inverse

# When hallucinating, confused or similar
OPTIONS=hilite_status:condition/minor_troubles/yellow
OPTIONS=hilite_status:condition/major_troubles/red
OPTIONS=hilite_status:condition/movement/lightcyan&bold

OPTIONS=hilite_status:gold/always/yellow

OPTIONS=hilite_status:hitpoints/100%/white
OPTIONS=hilite_status:hitpoints/<100%/green
OPTIONS=hilite_status:hitpoints/<60%/yellow
OPTIONS=hilite_status:hitpoints/<40%/red
OPTIONS=hilite_status:hitpoints/<20%/red&inverse

OPTIONS=hilite_status:power/100%/white
OPTIONS=hilite_status:power/<100%/green
OPTIONS=hilite_status:power/<60%/yellow
OPTIONS=hilite_status:power/<40%/red
OPTIONS=hilite_status:power/<20%/red&inverse

OPTIONS=hilite_status:carrying-capacity/burdened/yellow/stressed/orange
OPTIONS=hilite_status:carrying-capacity/up/red&inverse/down/white&inverse

OPTIONS=hilite_status:experience-level/up/green/down/red

OPTIONS=hilite_status:characteristics/always/red/>7/orange/>9/yellow/>11/white
OPTIONS=hilite_status:characteristics/up/green&inverse/down/red&inverse

OPTIONS=hilite_status:armor-class/up/red&inverse/down/green&inverse


# OPTIONS=windowtype:curses
OPTIONS=windowtype:tty
OPTIONS=symset:IBMGraphics


OPTIONS=menucolors
MENUCOLOR="^an? .*"=white&dim
MENUCOLOR="^[0-9]+ .*"=white&dim
MENUCOLOR=" blessed "=green
MENUCOLOR=" holy water"=green
MENUCOLOR=" uncursed "=white
MENUCOLOR=" cursed "=red
MENUCOLOR=" cursed .* (being worn)"=orange&bold
MENUCOLOR=":0)"=orange
MENUCOLOR="gold piece"=yellow
MENUCOLOR=" worthless piece.* glass"=white&dim

# Forgotten spell regexp
MENUCOLOR="[a-zA-Z] - [a-zA-Z ]+[ ]+[0-9]+\*[ ]+[a-z]+[ ]+[0-9]+%"=magenta
# This version will work on NAO.
# MENUCOLOR="[a-zA-Z ]+[ ]+[0-9]+\*[ ]+[a-z]+[ ]+[0-9]+%"=magenta


# OPTIONS=menu_objsyms:5

# https://nethackwiki.com/wiki/Custom_map_symbols
SYMBOLS=S_boulder:0
SYMBOLS=S_ghost:8



# https://nethackwiki.com/wiki/MSGTYPE
#
# displacing pets
MSGTYPE=hide "You swap places with .*"

# unclogging the screen
MSGTYPE=hide "Your tentacles suck the .*"

# items on floor
# MSGTYPE=norep "You see here a.*"

# delayed instadeaths
MSGTYPE=stop "The .* (grabs|swings itself around) you!"
MSGTYPE=stop "You don't feel very well."
MSGTYPE=stop "You are turning a little green."
MSGTYPE=stop "Your limbs are getting oozy."
MSGTYPE=stop "Your skin begins to peel away."
MSGTYPE=stop "You are turning into a green slime."
MSGTYPE=stop "You are slowing down."
MSGTYPE=stop "Your limbs are stiffening."
MSGTYPE=stop "It constricts your throat!"
MSGTYPE=stop "You find it hard to breathe."
MSGTYPE=stop "You're gasping for air."
MSGTYPE=stop "Your blood is having trouble reaching your brain."
MSGTYPE=stop "You can no longer breathe."
MSGTYPE=stop "You're turning blue."
MSGTYPE=stop "Your consciousness is fading."
MSGTYPE=stop "You feel deathly sick."
MSGTYPE=stop "You feel (much|even) worse."

# Things that aren't dangerous by themselves but could kill you if you don't notice.
MSGTYPE=stop "You fail to cast the spell correctly."
MSGTYPE=stop "You see here a c(hi|o)ckatrice corpse."
MSGTYPE=stop "You are beginning to feel weak."
MSGTYPE=stop "reluctant"

# Don't speed past wrest message when wresting
MSGTYPE=stop "You wrest .*"

# Don't miss the vibrating square
MSGTYPE=stop "You feel a strange vibration under your *."
MSGTYPE=stop "You feel a strange vibration beneath you."







#######################################
#            HIGHSCORE                #
#######################################

2026-04-24:
  1     111573  Lenn-Val-Hum-Fem-Law died in The Dungeons of Doom on
                level 19 [max 20].  Killed by strangulation, while
                disrobing.                                              -  [91]
